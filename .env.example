AUTH_MODE=hybrid
APP_BASE_URL=https://your-project.vercel.app
AUTH_ALLOWED_ORIGINS=https://your-project.vercel.app
SPOTIFY_REDIRECT_URI=https://your-project.vercel.app/api/auth/spotify/callback
SPOTIFY_PRODUCT_SCOPES="user-read-private playlist-modify-private playlist-modify-public"
SPOTIFY_MARKET=US
SPOTIFY_TOKEN_KMS_KEY_ID=

